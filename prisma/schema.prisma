generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FridgeItem {
  id           String    @id @default(cuid())
  householdId  String
  name         String
  quantity     Float
  unit         String
  expiresAt    DateTime
  reminderDays Int       @default(1)
  category     String    @default("products")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

model ShoppingItem {
  id          String    @id @default(cuid())
  householdId String
  name        String
  quantity    Float?
  unit        String?
  category    String    @default("products")
  checked     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

model Household {
  id                   String                @id @default(cuid())
  name                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  users                User[]
  fridgeItems          FridgeItem[]
  shoppingItems        ShoppingItem[]
  householdInvitations HouseholdInvitation[]
}

model User {
  id              String         @id @default(cuid())
  householdId     String
  email           String         @unique
  displayName     String
  passwordHash    String?
  authProvider    String         @default("password")
  providerSubject String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  household       Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  sessions        Session[]
  identities      AuthIdentity[]
  notifications   Notification[]
  sentInvitations HouseholdInvitation[] @relation("InvitationInviter")
  invitations     HouseholdInvitation[] @relation("InvitationInvitee")

  @@unique([authProvider, providerSubject])
  @@index([householdId])
}

model HouseholdInvitation {
  id          String    @id @default(cuid())
  householdId String
  inviterId   String
  inviteeId   String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  inviter     User      @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee     User      @relation("InvitationInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([householdId, inviteeId, status])
  @@index([inviteeId, status])
  @@index([householdId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  readAt    DateTime?
  data      String?
  dedupeKey String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, readAt, createdAt])
}

model AuthIdentity {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  subject   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
